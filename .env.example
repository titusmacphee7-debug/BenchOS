# Auth0 public frontend config.
# Put real values in .env.local only. Do not commit secret or local env files.
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=

# Required when calling Netlify Functions that verify Auth0 access tokens.
VITE_AUTH0_AUDIENCE=

# Server-only Auth0 settings for Netlify Functions.
# Set these in Netlify, not in browser code.
AUTH0_DOMAIN=
AUTH0_AUDIENCE=

# Server-only Auth0 Management API settings for account deletion.
# These must never be exposed to browser code.
AUTH0_MANAGEMENT_CLIENT_ID=
AUTH0_MANAGEMENT_CLIENT_SECRET=
AUTH0_MANAGEMENT_AUDIENCE=
